// ─────────────────────────────────────────────────────────────────────────────
// Mini ERP – From Demand to Delivery
// Prisma Schema  |  PostgreSQL
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═════════════════════════════════════════════════════════════════════════════

// ── Auth ─────────────────────────────────────────────────────────────────────

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Products ─────────────────────────────────────────────────────────────────

enum ProductType {
  RAW_MATERIAL
  FINISHED_GOOD
  SEMI_FINISHED
  CONSUMABLE
}

enum ProcureType {
  MTS // Make To Stock  – buy/manufacture ahead of demand
  MTO // Make To Order  – only when a sales order arrives
}

// ── Sales ─────────────────────────────────────────────────────────────────────

enum SOStatus {
  draft
  confirmed
  in_production       // waiting for MO to complete
  ready_to_dispatch
  dispatched
  delivered
  cancelled
}

// ── Purchase ──────────────────────────────────────────────────────────────────

enum POStatus {
  draft
  confirmed
  partially_received
  received
  cancelled
}

enum BillStatus {
  pending_payment
  approved_for_payment
  paid
  void
}

// ── Manufacturing ─────────────────────────────────────────────────────────────

enum MOStatus {
  draft
  confirmed
  in_progress
  completed
  cancelled
}

enum WOStatus {
  pending
  in_progress
  completed
  on_hold
}

// ── Inventory ─────────────────────────────────────────────────────────────────

/// Direction of a stock movement recorded in the ledger
enum LedgerDirection {
  IN       // stock enters warehouse
  OUT      // stock leaves warehouse
  RESERVE  // soft-lock (no physical movement)
  RELEASE  // undo a reservation (no physical movement)
}

// ── Audit ─────────────────────────────────────────────────────────────────────

enum AuditAction {
  create
  update
  delete
  status_change
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 0 – AUTHENTICATION & ACCESS CONTROL
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id                String             @id @default(uuid()) @map("user_id") @db.Uuid
  login_id          String             @unique @db.VarChar(50)
  email             String             @unique @db.VarChar(255)
  password          String             @db.Text
  is_admin          Boolean            @default(false)
  status            RegistrationStatus @default(PENDING)
  requested_modules Int[]              // module IDs user requested access to
  rejected_reason   String?            @db.Text
  last_login_at     DateTime?          @db.Timestamptz()
  created_at        DateTime           @default(now()) @db.Timestamptz()
  updated_at        DateTime           @updatedAt @db.Timestamptz()

  // Auth relations
  profile        UserProfile?
  module_access  UserModuleAccess[] @relation("UserAccess")
  granted_access UserModuleAccess[] @relation("GrantedByAdmin")
  refresh_tokens RefreshToken[]
  password_tokens PasswordResetToken[]

  // Business relations
  sales_orders_created        SalesOrder[]         @relation("CreatedSalesOrders")
  sales_orders_salesperson    SalesOrder[]         @relation("SalespersonOrders")
  purchase_orders_created     PurchaseOrder[]      @relation("CreatedPurchaseOrders")
  purchase_orders_responsible PurchaseOrder[]      @relation("ResponsiblePurchaseOrders")
  mfg_orders      ManufacturingOrder[]
  goods_receipts  GoodsReceipt[]
  vendor_bills    VendorBill[]
  stock_ledger      StockLedger[]
  audit_logs        AuditLog[]
  stock_transfers   StockTransfer[]
  stock_adjustments StockAdjustment[]

  @@index([email])
  @@index([login_id])
  @@map("users")
}

model UserProfile {
  id            String   @id @default(uuid()) @map("profile_id") @db.Uuid
  user_id       String   @unique @db.Uuid
  full_name     String   @db.VarChar(150)
  position      String   @db.VarChar(100)
  email_display String   @db.VarChar(255)
  address       String?  @db.Text
  mobile_no     String?  @db.VarChar(15)
  profile_photo String?  @db.Text
  updated_at    DateTime @updatedAt @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// ERP modules (Products, Sales, Purchase, Manufacturing, Inventory, …)
model Module {
  id          Int      @id @default(autoincrement()) @map("module_id")
  module_name String   @unique @db.VarChar(50)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz()

  user_access UserModuleAccess[]

  @@map("modules")
}

/// Which modules each user can access (granted by an admin)
model UserModuleAccess {
  id         Int      @id @default(autoincrement()) @map("access_id")
  user_id    String   @db.Uuid
  module_id  Int
  granted_at DateTime @default(now()) @db.Timestamptz()
  granted_by String?  @db.Uuid

  user   User   @relation("UserAccess", fields: [user_id], references: [id], onDelete: Cascade)
  module Module @relation(fields: [module_id], references: [id], onDelete: Cascade)
  admin  User?  @relation("GrantedByAdmin", fields: [granted_by], references: [id], onDelete: SetNull)

  @@unique([user_id, module_id])
  @@map("user_module_access")
}

model RefreshToken {
  id         String   @id @default(uuid()) @map("token_id") @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.Text
  is_revoked Boolean  @default(false)
  issued_at  DateTime @default(now()) @db.Timestamptz()
  expires_at DateTime @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(128)
  expires_at DateTime @db.Timestamptz()
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
  @@map("password_reset_tokens")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 1 – PRODUCTS
// ═════════════════════════════════════════════════════════════════════════════

model Product {
  id                String      @id @default(uuid()) @db.Uuid
  name              String      @db.VarChar(200)
  sku               String?     @unique @db.VarChar(50) // optional internal code
  type              ProductType @default(RAW_MATERIAL)
  sales_price       Decimal     @db.Decimal(12, 2)
  cost_price        Decimal     @db.Decimal(12, 2)
  procurement_type  ProcureType @default(MTS)
  procurement_method String      @default("PURCHASE") @db.VarChar(20) // PURCHASE or MANUFACTURING
  procure_on_demand Boolean     @default(false)
  vendor_id         String?     @db.Uuid // preferred vendor for MTS-purchase products
  bom_id            String?     @db.Uuid // default BOM for MTO-manufacture products
  warehouse_id      String?     @db.Uuid // preferred warehouse
  unit              String      @default("pcs") @db.VarChar(20)
  image_url         String?     @db.Text
  created_at        DateTime    @default(now()) @db.Timestamptz()
  updated_at        DateTime    @updatedAt @db.Timestamptz()

  // Forward relations
  vendor        Vendor?          @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  bom_reference BillOfMaterials? @relation("ProductBom", fields: [bom_id], references: [id], onDelete: SetNull)
  warehouse     Warehouse?       @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)

  // Reverse / back-reference relations
  bom              BillOfMaterials?      @relation("BomProduct")
  bom_lines        BOMLine[]             // this product is a component inside some BOMs
  inventory        Inventory[]
  so_lines         SalesOrderLine[]
  stock_transfers  StockTransfer[]
  stock_adjustments StockAdjustment[]
  po_lines         PurchaseOrderLine[]
  mfg_orders       ManufacturingOrder[]
  stock_ledger     StockLedger[]
  reservations     StockReservation[]
  receipt_lines    GoodsReceiptLine[]
  suggestions      ProcurementSuggestion[]
  risk_alert       RiskAlert?
  quotation_lines  SalesQuotationLine[]
  delivery_lines   SalesDeliveryLine[]

  @@index([name])
  @@index([type])
  @@index([procurement_type])
  @@index([vendor_id])
  @@map("products")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 2 – BILL OF MATERIALS (BoM)
// ═════════════════════════════════════════════════════════════════════════════

/// One BoM per finished product.  Defines components + operations.
model BillOfMaterials {
  id         String @id @default(uuid()) @db.Uuid
  product_id String @unique @db.Uuid // the finished-good this BoM produces

  // Relations
  product    Product   @relation("BomProduct", fields: [product_id], references: [id], onDelete: Cascade)
  products   Product[] @relation("ProductBom") // products that reference this BOM
  lines      BOMLine[]
  mfg_orders ManufacturingOrder[]

  @@map("boms")
}

/// Each row = one component required by the BoM + which operation uses it
model BOMLine {
  id                     String  @id @default(uuid()) @db.Uuid
  bom_id                 String  @db.Uuid
  component_product_id   String  @db.Uuid
  qty_per_unit           Decimal @db.Decimal(12, 3) // qty needed per 1 finished unit
  operation              String  @db.VarChar(100) // which production step uses this component
  expected_duration_mins Int     @default(0)
  work_center            String? @db.VarChar(100)

  bom       BillOfMaterials @relation(fields: [bom_id], references: [id], onDelete: Cascade)
  component Product         @relation(fields: [component_product_id], references: [id], onDelete: Restrict)

  @@index([bom_id])
  @@index([component_product_id])
  @@map("bom_lines")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 3 – SALES
// ═════════════════════════════════════════════════════════════════════════════

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  customer_code  String   @unique @db.VarChar(20)
  name           String   @db.VarChar(200)
  contact_person String?  @db.VarChar(100)
  email          String?  @unique @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  address        String?  @db.Text
  gst_no         String?  @db.VarChar(30)
  credit_limit   Decimal? @db.Decimal(14, 2)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @updatedAt @db.Timestamptz()

  sales_orders SalesOrder[]
  quotations   SalesQuotation[]
  deliveries   SalesDelivery[]

  @@index([email])
  @@map("customers")
}

model SalesOrder {
  id                     String   @id @default(uuid()) @db.Uuid
  order_number           String   @unique @db.VarChar(30)
  customer_id            String   @db.Uuid
  order_date             DateTime @default(now()) @db.Date
  expected_delivery_date DateTime? @db.Date
  status                 SOStatus @default(draft)
  remarks                String?  @db.Text
  created_by             String?  @db.Uuid
  salesperson_id         String?  @db.Uuid
  customer_address       String?  @db.Text
  created_at             DateTime @default(now()) @db.Timestamptz()
  updated_at             DateTime @updatedAt @db.Timestamptz()

  customer    Customer         @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  user        User?            @relation("CreatedSalesOrders", fields: [created_by], references: [id], onDelete: SetNull)
  salesperson User?            @relation("SalespersonOrders", fields: [salesperson_id], references: [id], onDelete: SetNull)
  lines       SalesOrderLine[]
  deliveries  SalesDelivery[]

  @@index([customer_id])
  @@index([status])
  @@index([created_by])
  @@index([salesperson_id])
  @@map("sales_orders")
}

model SalesOrderLine {
  id            String  @id @default(uuid()) @db.Uuid
  so_id         String  @db.Uuid
  product_id    String  @db.Uuid
  ordered_qty   Decimal @db.Decimal(12, 3)
  delivered_qty Decimal @default(0) @db.Decimal(12, 3)
  unit_price    Decimal @db.Decimal(12, 2)
  /// Qty that could not be fulfilled from stock (triggers procurement)
  shortage_qty  Decimal @default(0) @db.Decimal(12, 3)

  order   SalesOrder @relation(fields: [so_id], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([so_id])
  @@index([product_id])
  @@map("sales_order_lines")
}

model SalesQuotation {
  id               String               @id @default(uuid()) @db.Uuid
  quotation_number String               @unique @db.VarChar(30)
  customer_id      String               @db.Uuid
  date             DateTime             @default(now()) @db.Date
  expiry_date      DateTime             @db.Date
  amount           Decimal              @db.Decimal(12, 2)
  status           String               @default("Draft") @db.VarChar(20) // Draft | Sent | Approved
  remarks          String?              @db.Text
  created_at       DateTime             @default(now()) @db.Timestamptz()
  updated_at       DateTime             @updatedAt @db.Timestamptz()

  customer         Customer             @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  lines            SalesQuotationLine[]

  @@index([customer_id])
  @@index([status])
  @@map("sales_quotations")
}

model SalesQuotationLine {
  id           String         @id @default(uuid()) @db.Uuid
  quotation_id String         @db.Uuid
  product_id   String         @db.Uuid
  qty          Decimal        @db.Decimal(12, 3)
  price        Decimal        @db.Decimal(12, 2)
  discount     Decimal        @default(0) @db.Decimal(5, 2)
  tax          Decimal        @default(18) @db.Decimal(5, 2)
  total        Decimal        @db.Decimal(12, 2)

  quotation    SalesQuotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([quotation_id])
  @@index([product_id])
  @@map("sales_quotation_lines")
}

model SalesDelivery {
  id               String              @id @default(uuid()) @db.Uuid
  delivery_number  String              @unique @db.VarChar(30)
  so_id            String              @db.Uuid
  customer_id      String              @db.Uuid
  delivery_date    DateTime            @db.Date
  status           String              @default("Pending") @db.VarChar(20) // Pending | Packed | Dispatched | Delivered
  shipping_address String              @db.Text
  dispatch_date    DateTime?           @db.Date
  created_at       DateTime            @default(now()) @db.Timestamptz()
  updated_at       DateTime            @updatedAt @db.Timestamptz()

  sales_order      SalesOrder          @relation(fields: [so_id], references: [id], onDelete: Restrict)
  customer         Customer            @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  lines            SalesDeliveryLine[]

  @@index([so_id])
  @@index([customer_id])
  @@index([status])
  @@map("sales_deliveries")
}

model SalesDeliveryLine {
  id          String        @id @default(uuid()) @db.Uuid
  delivery_id String        @db.Uuid
  product_id  String        @db.Uuid
  qty         Decimal       @db.Decimal(12, 3)

  delivery    SalesDelivery @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([delivery_id])
  @@index([product_id])
  @@map("sales_delivery_lines")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 4 – PURCHASE
// ═════════════════════════════════════════════════════════════════════════════

model Vendor {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(200)
  contact_person String?  @db.VarChar(100)
  email          String?  @unique @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  address        String?  @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @updatedAt @db.Timestamptz()

  products        Product[]
  purchase_orders PurchaseOrder[]
  vendor_bills    VendorBill[]

  @@map("vendors")
}

model PurchaseOrder {
  id                    String   @id @default(uuid()) @db.Uuid
  po_number             String   @unique @db.VarChar(30)
  vendor_id             String   @db.Uuid
  status                POStatus @default(draft)
  remarks               String?  @db.Text
  created_by            String?  @db.Uuid
  responsible_person_id String?  @db.Uuid
  vendor_address        String?  @db.Text
  created_at            DateTime @default(now()) @db.Timestamptz()
  updated_at            DateTime @updatedAt @db.Timestamptz()

  vendor             Vendor              @relation(fields: [vendor_id], references: [id], onDelete: Restrict)
  user               User?               @relation("CreatedPurchaseOrders", fields: [created_by], references: [id], onDelete: SetNull)
  responsible_person User?               @relation("ResponsiblePurchaseOrders", fields: [responsible_person_id], references: [id], onDelete: SetNull)
  lines              PurchaseOrderLine[]
  receipts           GoodsReceipt[]
  bills              VendorBill[]

  @@index([vendor_id])
  @@index([status])
  @@index([created_by])
  @@index([responsible_person_id])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id           String  @id @default(uuid()) @db.Uuid
  po_id        String  @db.Uuid
  product_id   String  @db.Uuid
  ordered_qty  Decimal @db.Decimal(12, 3)
  received_qty Decimal @default(0) @db.Decimal(12, 3)
  unit_price   Decimal @db.Decimal(12, 2)

  order         PurchaseOrder      @relation(fields: [po_id], references: [id], onDelete: Cascade)
  product       Product            @relation(fields: [product_id], references: [id], onDelete: Restrict)
  receipt_lines GoodsReceiptLine[]

  @@index([po_id])
  @@index([product_id])
  @@map("purchase_order_lines")
}

/// Physical receipt of goods against a confirmed PO
model GoodsReceipt {
  id                String   @id @default(uuid()) @db.Uuid
  receipt_number    String   @unique @db.VarChar(50)
  po_id             String   @db.Uuid
  delivery_note_ref String?  @db.VarChar(100)
  received_by       String?  @db.Uuid
  received_at       DateTime @default(now()) @db.Timestamptz()
  created_at        DateTime @default(now()) @db.Timestamptz()

  purchase_order PurchaseOrder      @relation(fields: [po_id], references: [id], onDelete: Restrict)
  user           User?              @relation(fields: [received_by], references: [id], onDelete: SetNull)
  lines          GoodsReceiptLine[]

  @@index([po_id])
  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id           String  @id @default(uuid()) @db.Uuid
  receipt_id   String  @db.Uuid
  product_id   String  @db.Uuid
  po_line_id   String  @db.Uuid
  qty_received Decimal @db.Decimal(12, 3)
  remarks      String? @db.Text

  receipt GoodsReceipt      @relation(fields: [receipt_id], references: [id], onDelete: Cascade)
  product Product           @relation(fields: [product_id], references: [id], onDelete: Restrict)
  po_line PurchaseOrderLine @relation(fields: [po_line_id], references: [id], onDelete: Restrict)

  @@index([receipt_id])
  @@index([product_id])
  @@index([po_line_id])
  @@map("goods_receipt_lines")
}

/// Vendor invoice linked to a PO
model VendorBill {
  id                String     @id @default(uuid()) @db.Uuid
  bill_number       String     @unique @db.VarChar(100)
  po_id             String     @db.Uuid
  vendor_id         String     @db.Uuid
  invoice_date      DateTime   @db.Date
  due_date          DateTime   @db.Date
  subtotal          Decimal    @db.Decimal(12, 2)
  tax               Decimal    @default(0) @db.Decimal(12, 2)
  total_amount      Decimal    @db.Decimal(12, 2)
  status            BillStatus @default(pending_payment)
  attachment_url    String?    @db.Text
  payment_reference String?    @db.VarChar(100)
  paid_at           DateTime?  @db.Timestamptz()
  paid_by           String?    @db.Uuid
  created_at        DateTime   @default(now()) @db.Timestamptz()
  updated_at        DateTime   @updatedAt @db.Timestamptz()

  purchase_order PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Restrict)
  vendor         Vendor        @relation(fields: [vendor_id], references: [id], onDelete: Restrict)
  user           User?         @relation(fields: [paid_by], references: [id], onDelete: SetNull)

  @@index([po_id])
  @@index([vendor_id])
  @@index([status])
  @@map("vendor_bills")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 5 – MANUFACTURING
// ═════════════════════════════════════════════════════════════════════════════

model ManufacturingOrder {
  id           String   @id @default(uuid()) @db.Uuid
  mo_number    String   @unique @db.VarChar(30)
  product_id   String   @db.Uuid
  bom_id       String   @db.Uuid
  quantity     Decimal  @db.Decimal(12, 3)
  produced_qty Decimal  @default(0) @db.Decimal(12, 3)
  status       MOStatus @default(draft)
  /// Link back to the sales order that triggered this MO (MTO flow)
  so_id        String?  @db.Uuid
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz()
  updated_at   DateTime @updatedAt @db.Timestamptz()

  product     Product         @relation(fields: [product_id], references: [id], onDelete: Restrict)
  bom         BillOfMaterials @relation(fields: [bom_id], references: [id], onDelete: Restrict)
  user        User?           @relation(fields: [created_by], references: [id], onDelete: SetNull)
  work_orders WorkOrder[]

  @@index([product_id])
  @@index([status])
  @@index([so_id])
  @@map("manufacturing_orders")
}

/// One work order = one operation step (assembly, painting, packing …)
model WorkOrder {
  id                 String    @id @default(uuid()) @db.Uuid
  mo_id              String    @db.Uuid
  operation          String    @db.VarChar(100)
  work_center        String    @db.VarChar(100)
  duration_mins      Int       @default(0)
  real_duration_mins Int       @default(0)
  status             WOStatus  @default(pending)
  started_at         DateTime? @db.Timestamptz()
  completed_at       DateTime? @db.Timestamptz()

  mfg_order ManufacturingOrder @relation(fields: [mo_id], references: [id], onDelete: Cascade)

  @@index([mo_id])
  @@index([status])
  @@map("work_orders")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 6 – INVENTORY & STOCK
// ═════════════════════════════════════════════════════════════════════════════

/// Current stock snapshot per product-warehouse combination
model Inventory {
  id               String    @id @default(uuid()) @db.Uuid
  product_id       String    @db.Uuid
  warehouse_id     String    @db.Uuid
  on_hand_qty      Decimal   @default(0) @db.Decimal(12, 3)
  reserved_qty     Decimal   @default(0) @db.Decimal(12, 3)
  // free_to_use = on_hand_qty − reserved_qty  (computed in application layer)
  reorder_level    Decimal   @default(0) @db.Decimal(12, 3)
  max_stock_level  Decimal?  @db.Decimal(12, 3)
  average_cost     Decimal?  @db.Decimal(12, 2)
  last_movement_at DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @updatedAt @db.Timestamptz()

  product   Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@unique([product_id, warehouse_id])
  @@map("inventory")
}

/// Immutable ledger – every stock movement creates a new row
model StockLedger {
  id             String          @id @default(uuid()) @db.Uuid
  product_id     String          @db.Uuid
  warehouse_id   String          @db.Uuid
  movement_type  String          @db.VarChar(50)  // e.g. PURCHASE_RECEIPT, SALES_DELIVERY, MANUFACTURING_CONSUMPTION …
  direction      LedgerDirection
  reference_type String?         @db.VarChar(50)  // GOODS_RECEIPT | SALES_ORDER | MANUFACTURING_ORDER | STOCK_TRANSFER | STOCK_ADJUSTMENT
  reference_id   String?         @db.Uuid         // FK to the source document
  quantity       Decimal         @db.Decimal(12, 3)
  stock_before   Decimal         @db.Decimal(12, 3)
  stock_after    Decimal         @db.Decimal(12, 3)
  remarks        String?         @db.Text
  created_by     String?         @db.Uuid
  created_at     DateTime        @default(now()) @db.Timestamptz()

  product   Product   @relation(fields: [product_id], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Restrict)
  user      User?     @relation(fields: [created_by], references: [id], onDelete: SetNull)

  @@index([product_id, created_at(sort: Desc)])
  @@index([warehouse_id])
  @@index([movement_type])
  @@index([reference_type, reference_id])
  @@map("stock_ledger")
}

/// Active soft-lock records (reservation for SO / MO)
model StockReservation {
  id           String   @id @default(uuid()) @db.Uuid
  product_id   String   @db.Uuid
  warehouse_id String?  @db.Uuid
  source_type  String   @db.VarChar(50) // SALES_ORDER | MANUFACTURING_ORDER
  source_id    String   @db.Uuid
  reserved_qty Decimal  @db.Decimal(12, 3)
  status       String   @default("ACTIVE") @db.VarChar(20) // ACTIVE | RELEASED | CONSUMED
  created_at   DateTime @default(now()) @db.Timestamptz()

  product   Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  warehouse Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([warehouse_id])
  @@index([source_type, source_id])
  @@map("stock_reservations")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 7 – PROCUREMENT AUTOMATION
// ═════════════════════════════════════════════════════════════════════════════

/// Auto-generated suggestions when shortage is detected (MTO trigger)
model ProcurementSuggestion {
  id                 String   @id @default(uuid()) @db.Uuid
  product_id         String   @db.Uuid
  so_id              String?  @db.Uuid  // sales order that caused the shortage
  current_stock      Decimal  @db.Decimal(12, 3)
  shortage_qty       Decimal  @db.Decimal(12, 3)
  /// PURCHASE → create PO   |   MANUFACTURING → create MO
  procurement_source String   @db.VarChar(20)
  /// PENDING | PO_CREATED | MO_CREATED | IGNORED
  status             String   @default("PENDING") @db.VarChar(20)
  reason             String?  @db.Text
  created_at         DateTime @default(now()) @db.Timestamptz()
  updated_at         DateTime @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([status])
  @@map("procurement_suggestions")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 8 – AUDIT LOGS
// ═════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  user_id    String?     @db.Uuid
  model_name String      @db.VarChar(100) // e.g. "SalesOrder"
  record_id  String      @db.Uuid
  action     AuditAction
  old_value  Json?
  new_value  Json?
  created_at DateTime    @default(now()) @db.Timestamptz()

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([model_name, record_id])
  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("audit_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 9 – RISK & ALERTS  (AI / owner dashboard support)
// ═════════════════════════════════════════════════════════════════════════════

/// Per-product stock risk alert (one active alert per product)
model RiskAlert {
  id                   String   @id @default(uuid()) @db.Uuid
  product_id           String   @unique @db.Uuid
  current_stock        Decimal? @db.Decimal(12, 3)
  required_stock       Decimal? @db.Decimal(12, 3)
  deficit              Decimal? @db.Decimal(12, 3)
  /// HIGH | MEDIUM | LOW
  severity             String   @db.VarChar(10)
  recommended_supplier String?  @db.VarChar(200)
  lead_time_days       Int?
  is_resolved          Boolean  @default(false)
  updated_at           DateTime @updatedAt @db.Timestamptz()

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("risk_alerts")
}

// ═════════════════════════════════════════════════════════════════════════════
// MODULE 10 – WAREHOUSES & STOCK TRANSFERS/ADJUSTMENTS
// ═════════════════════════════════════════════════════════════════════════════

model Warehouse {
  id             String   @id @default(uuid()) @map("warehouse_id") @db.Uuid
  warehouse_code String   @unique @db.VarChar(20)
  name           String   @db.VarChar(200)
  location       String   @db.Text
  manager        String   @db.VarChar(100)
  capacity       Int
  status         String   @default("Active") @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @updatedAt @db.Timestamptz()

  // Relations
  products         Product[]
  inventory        Inventory[]
  stock_ledger     StockLedger[]
  reservations     StockReservation[]
  transfers_source StockTransfer[]    @relation("SourceWarehouse")
  transfers_dest   StockTransfer[]    @relation("DestinationWarehouse")
  adjustments      StockAdjustment[]

  @@map("warehouses")
}

model StockTransfer {
  id                       String   @id @default(uuid()) @map("transfer_id") @db.Uuid
  transfer_number          String   @unique @db.VarChar(30)
  source_warehouse_id      String   @db.Uuid
  destination_warehouse_id String   @db.Uuid
  product_id               String   @db.Uuid
  qty                      Decimal  @db.Decimal(12, 3)
  status                   String   @default("Pending") @db.VarChar(20) // Pending | Completed | Cancelled
  date                     DateTime @default(now()) @db.Date
  reason                   String?  @db.Text
  created_by               String?  @db.Uuid
  created_at               DateTime @default(now()) @db.Timestamptz()
  updated_at               DateTime @updatedAt @db.Timestamptz()

  source_warehouse      Warehouse @relation("SourceWarehouse", fields: [source_warehouse_id], references: [id], onDelete: Restrict)
  destination_warehouse Warehouse @relation("DestinationWarehouse", fields: [destination_warehouse_id], references: [id], onDelete: Restrict)
  product               Product   @relation(fields: [product_id], references: [id], onDelete: Restrict)
  user                  User?     @relation(fields: [created_by], references: [id], onDelete: SetNull)

  @@index([source_warehouse_id])
  @@index([destination_warehouse_id])
  @@index([product_id])
  @@map("stock_transfers")
}

model StockAdjustment {
  id                String   @id @default(uuid()) @map("adjustment_id") @db.Uuid
  adjustment_number String   @unique @db.VarChar(30)
  product_id        String   @db.Uuid
  warehouse_id      String   @db.Uuid
  old_qty           Decimal  @db.Decimal(12, 3)
  new_qty           Decimal  @db.Decimal(12, 3)
  reason            String?  @db.Text
  created_by        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @updatedAt @db.Timestamptz()

  product   Product   @relation(fields: [product_id], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Restrict)
  user      User?     @relation(fields: [created_by], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@index([warehouse_id])
  @@map("stock_adjustments")
}

